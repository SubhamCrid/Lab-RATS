<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/decoy_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivUpdateIcon"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="24dp"
            android:src="@drawable/ic_sprocket_gear"
            app:tint="@color/decoy_icon_tint"
            android:contentDescription="System Update Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decoy_title"
            android:textColor="@color/decoy_text_main"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decoy_version"
            android:textColor="@color/decoy_text_sub"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decoy_security_patch"
            android:textColor="@color/decoy_text_sub"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <ProgressBar
            android:id="@+id/decoyProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnCheckUpdate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decoy_check_btn"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A73E8"
            app:cornerRadius="24dp" />

    </LinearLayout>

    <!-- Custom Pseudo-Toast for stealth -->
    <LinearLayout
        android:id="@+id/pseudoToast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="64dp"
        android:background="@drawable/toast_background"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_sprocket_gear"
            app:tint="@color/decoy_icon_tint"
            android:layout_marginEnd="10dp"
            android:contentDescription="Toast Icon" />

        <TextView
            android:id="@+id/pseudoToastText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/decoy_title"
            android:textColor="@color/decoy_background"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
